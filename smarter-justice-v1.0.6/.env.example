# Smarter Justice v1.0.6
APP_BASE_URL=https://smarterjustice.com
PORT=3000
OWNER_NOTIFICATION_EMAIL=reachrgnow@gmail.com
ADMIN_TOKEN=replace-with-long-owner-token
STAFF_SIGNUP_CODE=replace-with-long-staff-code
SESSION_SECRET=replace-with-long-random-secret

# Storage. For Render paid/pilot use, prefer DATABASE_URL plus a persistent disk mounted to RENDER_DISK_MOUNT_PATH
# or set SMARTER_JUSTICE_STORAGE_DIR to a mounted persistent storage path.
SMARTER_JUSTICE_STORAGE_DIR=./storage
RENDER_DISK_MOUNT_PATH=
DATABASE_URL=
PGSSLMODE=require
MAX_UPLOADS_PER_REQUEST=6
MAX_UPLOAD_BYTES=8388608
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.webp,.txt,.csv,.doc,.docx,.rtf,.eml,.msg
ALLOWED_UPLOAD_MIME_PREFIXES=application/pdf,image/,text/plain,text/csv,application/msword,application/vnd.openxmlformats-officedocument,application/rtf,message/rfc822,application/octet-stream
RATE_LIMIT_MAX=80
RATE_LIMIT_WINDOW_MS=600000
BODY_LIMIT_BYTES=14680064

# SMTP for real owner/user notifications. Without SMTP, notifications are spooled in storage/notifications.json.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional live chat. If unset, built-in help launcher links to Contact.
TAWK_PROPERTY_ID=
TAWK_WIDGET_ID=

# Stripe Checkout + webhook foundation. Add Price IDs from Stripe before charging real users.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_STARTER_REVIEW_PRICE_ID=
STRIPE_NOTICE_REVIEW_PRICE_ID=
STRIPE_FORM_PREP_PRICE_ID=
STRIPE_TAX_REVIEW_PRICE_ID=
STRIPE_ATTORNEY_REVIEW_PRICE_ID=
STRIPE_PROFESSIONAL_REVIEW_PRICE_ID=
