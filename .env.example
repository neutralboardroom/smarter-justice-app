# Smarter Justice v1.6.1
APP_BASE_URL=https://smarterjustice.com
PORT=3000
OWNER_NOTIFICATION_EMAIL=

# Owner account bootstrap. Set both values for the first production start, sign in,
# enable authenticator MFA, save the recovery codes securely, then remove both
# bootstrap values after the account is durably stored in PostgreSQL.
OWNER_ACCOUNT_NAME=Smarter Justice Owner
OWNER_ACCOUNT_EMAIL=
OWNER_ACCOUNT_PASSWORD=
OWNER_SESSION_HOURS=8

# Legacy migration access. Keep disabled in production. A token may be used only
# for local/test migration while the owner account is being introduced.
ALLOW_LEGACY_OWNER_TOKEN=false
OWNER_CONTROL_CENTER_TOKEN=
PORTAL_RULES_API_TOKEN=replace-with-a-separate-long-approved-portal-rules-token
ADMIN_TOKEN=replace-with-a-separate-long-staff-admin-token
# Keep false so admin tokens are sent in a request header, not placed in browser URLs or logs.
ALLOW_ADMIN_TOKEN_QUERY=false
# Reserved for later staff-account work; they do not replace ADMIN_TOKEN in v1.6.1.
STAFF_SIGNUP_CODE=
SESSION_SECRET=
PROFESSIONAL_SESSION_DAYS=14

# Production persistence is fail-closed. Sensitive writes are blocked in production
# unless DATABASE_URL is configured and healthy. Uploads additionally require a
# durable private disk. Local JSON remains available only for development and tests.
# When RENDER_DISK_MOUNT_PATH is present, it takes precedence over SMARTER_JUSTICE_STORAGE_DIR.
SMARTER_JUSTICE_STORAGE_DIR=./storage
RENDER_DISK_MOUNT_PATH=
DATABASE_URL=
PGSSLMODE=require
PG_CONNECT_TIMEOUT_MS=5000
MAX_UPLOADS_PER_REQUEST=6
MAX_UPLOAD_BYTES=8388608
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.webp,.txt,.csv,.doc,.docx,.rtf,.eml,.msg
ALLOWED_UPLOAD_MIME_PREFIXES=application/pdf,image/,text/plain,text/csv,application/msword,application/vnd.openxmlformats-officedocument,application/rtf,message/rfc822,application/octet-stream
RATE_LIMIT_MAX=80
RATE_LIMIT_WINDOW_MS=600000
BODY_LIMIT_BYTES=14680064

# SMTP is required for live professional password recovery and transactional messages.
# Without SMTP, non-production notifications remain in storage/notifications.json.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional live chat. If unset, built-in help launcher links to Contact.
TAWK_PROPERTY_ID=
TAWK_WIDGET_ID=

# Stripe Checkout + signed webhook foundation. Keep the controlled professional pilot
# paused until test-mode checkout, payment, renewal, failure, cancellation, and refund
# evidence is complete and the owner has deliberately opened the pilot controls.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_STARTER_REVIEW_PRICE_ID=
STRIPE_NOTICE_REVIEW_PRICE_ID=
STRIPE_FORM_PREP_PRICE_ID=
STRIPE_TAX_REVIEW_PRICE_ID=
STRIPE_ATTORNEY_REVIEW_PRICE_ID=
STRIPE_PROFESSIONAL_REVIEW_PRICE_ID=

# Optional AI-assisted starting-point summaries. Rules fallback works without these.
AI_REVIEW_ENABLED=false
AI_PROVIDER_ORDER=openai,anthropic,google,xai
AI_TIMEOUT_MS=12000
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=
XAI_API_KEY=
XAI_MODEL=
